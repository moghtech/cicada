-- ========
--  Secret
-- ========

DEFINE TABLE IF NOT EXISTS Secret SCHEMAFULL;

-- name
DEFINE FIELD OVERWRITE name 
  ON TABLE Secret 
  TYPE string;

-- data
fn::define_encrypted_data_field("Secret", "data");

-- Standard timestamp fields 'created_at', 'updated_at'
fn::define_timestamp_fields("Secret");

-------------
-- Indexes --
-------------

-- name | unique
DEFINE INDEX OVERWRITE NameUnique 
  ON TABLE Secret 
  FIELDS name 
  UNIQUE;
