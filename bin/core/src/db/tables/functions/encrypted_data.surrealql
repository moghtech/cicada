-- Easily initialize encrypted fields on other tables.
DEFINE FUNCTION OVERWRITE fn::define_encrypted_data_field(
  $table: string,
  $field: string,
) {
  DEFINE FIELD OVERWRITE $field
  ON TABLE $table
  TYPE option<{
    encryption_key: record<EncryptionKey>,
    key: string,
    key_nonce: string,
    data: string,
    data_nonce: string,
  }>
  REFERENCE ON DELETE REJECT;
};