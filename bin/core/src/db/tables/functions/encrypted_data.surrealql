DEFINE FUNCTION OVERWRITE fn::define_encrypted_data_fields(
  $table: string,
) {
  DEFINE FIELD OVERWRITE encryption_key
  ON TABLE $table
  TYPE option<record<EncryptionKey>>
  REFERENCE ON DELETE REJECT;

  DEFINE FIELD OVERWRITE data
  ON TABLE $table
  TYPE option<{
    key: string,
    key_nonce: string,
    data: string,
    data_nonce: string,
  }>;
};